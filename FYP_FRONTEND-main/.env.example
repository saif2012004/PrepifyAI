# PrepifyAI frontend (Expo) environment.
# Copy to `.env` and fill in. All EXPO_PUBLIC_* vars are exposed to the app bundle,
# so do NOT put real secrets here — only public client IDs / dev hostnames.

# ── API connection ────────────────────────────────────────────────
# Full base URL of the backend. If set, it wins over the host/port logic below.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:8001
EXPO_PUBLIC_API_PORT=8001
EXPO_PUBLIC_API_PREFIX=/api/v1
EXPO_PUBLIC_API_TIMEOUT_MS=20000

# ── Dev hosts (so emulators / devices can reach your PC) ───────────
# Physical device on the same Wi-Fi: your PC's LAN IPv4.
# EXPO_PUBLIC_DEV_LAN_HOST=192.168.1.10
# Android emulator reaches the host via 10.0.2.2 by default.
EXPO_PUBLIC_ANDROID_EMULATOR_HOST=10.0.2.2
# Set true if 10.0.2.2 NAT is unreliable on your host (uses the LAN host instead).
EXPO_PUBLIC_ANDROID_EMULATOR_USE_LAN_HOST=false
# iOS simulator usually reaches the host on localhost.
EXPO_PUBLIC_IOS_SIMULATOR_API_HOST=127.0.0.1

# ── Per-request timeouts (ms) ─────────────────────────────────────
EXPO_PUBLIC_AUTH_TIMEOUT_MS=20000
EXPO_PUBLIC_QUESTION_GEN_TIMEOUT_MS=60000
EXPO_PUBLIC_SUBMIT_ANSWER_TIMEOUT_MS=20000
EXPO_PUBLIC_ADAPTIVE_NEXT_TIMEOUT_MS=20000

# ── Google Sign-In (optional) ─────────────────────────────────────
# Public OAuth client IDs from Google Cloud Console.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
