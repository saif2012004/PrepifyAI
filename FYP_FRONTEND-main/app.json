{
  "expo": {
    "name": "PrepifyAI",
    "slug": "prepifyai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prepifyai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "googleClientId": "637493510997-3ehjgq5oc1f03nmo781p2i0v38v77pot.apps.googleusercontent.com"
    },
    "android": {
      "package": "com.prepifyai.app",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#2563EB"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prepifyai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PrepifyAI needs access to your camera to take profile pictures.",
        "NSPhotoLibraryUsageDescription": "PrepifyAI needs access to your photo library to select profile pictures.",
        "NSPhotoLibraryAddUsageDescription": "PrepifyAI needs access to save photos to your library.",
        "NSLocalNetworkUsageDescription": "PrepifyAI connects to your computer on the same Wi‑Fi for the PrepifyAI API during development.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router", "expo-font", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
