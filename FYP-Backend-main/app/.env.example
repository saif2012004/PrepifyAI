
# Database — Docker maps host 5433 -> container 5432. Use 127.0.0.1 on Windows if localhost fails.
DATABASE_URL=postgresql://postgres:i222579@127.0.0.1:5433/PrepifyAI_Main?sslmode=disable

# Embeddings column type for past_papers_questions (and consistency with pgvector).
# true  = SQLAlchemy uses vector(384); DB column must be vector (see scripts/migrate_past_papers_embedding_to_pgvector.sql if you get json vs vector errors).
# false = JSON storage (matches older DBs); no pgvector on that column.
USE_PGVECTOR=true

# Security
SECRET_KEY=i222579-FYP
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage
# Resolved relative to FYP-Backend-main (not process cwd) so PDFs match between upload and download.
UPLOAD_DIR=uploads
MAX_FILE_SIZE=209715200

# OCR Settings
TESSERACT_PATH=/usr/bin/tesseract

# Redis — optional; enables short TTL JSON cache for GET /subjects/ (see app/core/redis_cache.py).
# Start with: docker compose up -d from Complete_FYP or FYP-Backend-main
REDIS_URL=redis://localhost:6379/0

# Past papers: on API startup, import repo past_papers/**/*.json (idempotent). First run may be slow (embeddings model).
# Set to false to skip autoload (you can still run: python load_past_papers_json.py).
PAST_PAPERS_JSON_AUTOLOAD=true

# When true, new AI questions are ``pending`` until approved via /api/v1/admin/questions/...
REQUIRE_GENERATED_QUESTION_APPROVAL=false

# When true, 500 responses may include short DB error hints (local dev only; never in production).
DEBUG_API=false

# When true, duplicate (board, class_level, subject_name) subject rows raise HTTP 409 instead of using lowest id.
SUBJECT_DUPLICATE_STRICT=false

# AI question generation (Groq + RAG). When false, the app gets empty lists (mobile used to blame GROQ wrongly).
QUESTION_GENERATION_ENABLED=false

# When true, RAG uses only textbook_chunks for the resolved subject_id (recommended). When false, legacy global books_chunks.json retrieval is used.
# QUESTION_GENERATION_STRICT_SYLLABUS=true

# Hard max seconds for Groq+RAG in the request worker (default 60). Prevents client/proxy timeouts.
# QUESTION_GENERATION_HARD_CAP_SEC=60
# Redis TTL for repeated identical generate-questions bodies (requires REDIS_URL).
# QUESTION_GENERATION_REDIS_TTL_SEC=600
# QUESTION_GENERATION_CACHE_ENABLED=true

# Groq LLM — required for POST /api/v1/questions/generate-questions/ when QUESTION_GENERATION_ENABLED=true
# Put GROQ_API_KEY in this file or in FYP-Backend-main/.env; if both set, app/.env wins.
# GROQ_API_KEY=gsk_your_key_here

# Default is llama-3.3-70b-versatile (full count + valid JSON in one shot).
# Drop to llama-3.1-8b-instant only if Groq free-tier rate limits bite.
# GROQ_QUESTION_MODEL=llama-3.3-70b-versatile
# Smaller = faster Groq (defaults: 8000 context, 3 chunks, 4096 max output). Raise if JSON truncates.
# GROQ_CONTEXT_MAX_CHARS=8000
# GROQ_MAX_OUTPUT_TOKENS=4096
# RAG_TOP_K=3
# Question generation: per-qtype floors are short>=120s, MCQ>=180s, long>=220s (combined with QUESTION_GENERATION_TIMEOUT_SEC).
# QUESTION_GENERATION_TIMEOUT_SEC=60
# 0 = no extra cap (recommended). If set (e.g. 90), asyncio wait is min(per-qtype timeout, this value).
# QUESTION_GENERATION_LIVE_MAX_SEC=0
# Extra warmup if you set RETRIEVER_WARMUP_ON_STARTUP=true (otherwise Groq key still triggers a background warmup).
# RETRIEVER_WARMUP_ON_STARTUP=true
# Block all HTTP until SentenceTransformer+FAISS load (slow startup; can look like "login timeout" from the app).
# RETRIEVER_BLOCKING_WARMUP=true
