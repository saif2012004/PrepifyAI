# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/prepifyai

# Embedding Storage Configuration
# Options: "true" (pgvector) or "false" (JSON)
# pgvector requires PostgreSQL pgvector extension to be installed
# For development without pgvector, set to "false"
USE_PGVECTOR=true

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=30

# Application Configuration
DEBUG=False
ENVIRONMENT=development
